{
  "version": 2,
  "builds": [
    {
      "src": "forexai_pro/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "forexai_pro/wsgi.py"
    }
  ]
}
